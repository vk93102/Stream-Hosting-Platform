# ════════════════════════════════════════════════════════════════════════════
#  SIL IRL Hosting Platform  –  Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production               # development | production
LOG_LEVEL=info                    # error | warn | info | debug
CORS_ORIGIN=*                     # restrict to your frontend domain in prod

# Public IP or hostname of this server – used in ingest URLs shown to users
SERVER_PUBLIC_IP=YOUR_SERVER_IP_OR_HOSTNAME

# ─── Database  (Supabase / PostgreSQL) ───────────────────────────────────────
# Third-party: https://supabase.com
#
# Use the "Transaction" pooler URL from:
#   Supabase Dashboard → Project → Settings → Database → Connection Pooling
#   Mode: Transaction   Port: 5432
#
# Format: postgresql://<user>.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Connection pool tuning (optional – defaults shown)
DB_POOL_MAX=10                    # max simultaneous PG connections from this process
DB_IDLE_TIMEOUT_MS=60000          # release idle connections after 60 s
DB_CONNECT_TIMEOUT_MS=5000        # fail-fast if pool can't get a connection in 5 s
DB_STATEMENT_TIMEOUT_MS=10000     # kill any query that runs > 10 s

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:  openssl rand -hex 48
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE
JWT_EXPIRES_IN=7d                 # token lifetime (e.g. 1d, 7d, 30d)

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# All /api/admin/* endpoints require header:  x-admin-secret: <value>
# REQUIRED in production. Generate with:  openssl rand -hex 32
ADMIN_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE

# ─── RTMP Ingest  (nginx-rtmp-module) ────────────────────────────────────────
# Third-party: nginx with nginx-rtmp-module compiled
# nginx calls on_publish / on_done webhooks → this server
RTMP_LOCAL=rtmp://127.0.0.1/live
NGINX_RTMP_API=http://127.0.0.1:8080/control

# ─── SRT Ingest  (MediaMTX) ──────────────────────────────────────────────────
# Third-party: https://github.com/bluenviron/mediamtx
# MediaMTX calls onPublish / onUnpublish webhooks → this server
# streamHealth.js polls the MediaMTX REST API for bitrate / packet-loss metrics
SRT_SERVER=127.0.0.1
SRT_PORT=9999
MEDIAMTX_API=http://127.0.0.1:9997

# ─── BRB / Anti-Scuff Layer ──────────────────────────────────────────────────
# Grace period (ms) before BRB FFmpeg loop starts after signal drop.
# During this window the streamer can reconnect with no visible interruption.
BRB_GRACE_MS=10000                # 10 seconds default

