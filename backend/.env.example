# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=*

# Public IP of this server (used in ingest URLs shown to users)
SERVER_PUBLIC_IP=YOUR_SERVER_PUBLIC_IP

# ─── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── RTMP Ingest (nginx-rtmp) ─────────────────────────────────────────────────
RTMP_LOCAL=rtmp://127.0.0.1/live
NGINX_RTMP_API=http://127.0.0.1:8080/control

# ─── SRT Ingest (MediaMTX) ────────────────────────────────────────────────────
SRT_SERVER=127.0.0.1
SRT_PORT=9999
MEDIAMTX_API=http://127.0.0.1:9997

# ─── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_SECRET=change-this-admin-secret

# ─── VM Provisioning ──────────────────────────────────────────────────────────
VM_PROVIDER=digitalocean        # digitalocean | aws

# DigitalOcean (for OBS VMs)
DO_TOKEN=your_digitalocean_api_token
DO_REGION=sgp1                  # Singapore (closest to Asia IRL streamers)
DO_SIZE=s-2vcpu-4gb             # $24/mo droplet
DO_IMAGE=ubuntu-22-04-x64

# AWS (alternative VM provider)
AWS_REGION=ap-southeast-1
AWS_INSTANCE_TYPE=t3.medium
AWS_AMI_ID=ami-xxxxxxxxxxxxxxxxx
